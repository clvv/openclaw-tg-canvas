BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789
JWT_SECRET=generate-a-random-secret-here
PORT=3721
JWT_TTL_SECONDS=900
INIT_DATA_MAX_AGE_SECONDS=300
RATE_LIMIT_AUTH_PER_MIN=30
RATE_LIMIT_STATE_PER_MIN=120
MINIAPP_URL=https://your-tunnel.trycloudflare.com
# PUSH_TOKEN is REQUIRED — generate with: openssl rand -hex 32
# Cloudflared bypasses the loopback IP check; this token is your only /push + /clear protection.
PUSH_TOKEN=generate-with-openssl-rand-hex-32
TG_CANVAS_URL=http://127.0.0.1:3721

# --- OpenClaw Control UI proxy (optional, off by default) ---
# Proxies /oc/* to the local OpenClaw gateway so you can access Control UI
# through the Mini App. Must be explicitly opted into with ENABLE_OPENCLAW_PROXY=true.
# The server does NOT read any local credential files — if auth is needed,
# set OPENCLAW_GATEWAY_TOKEN explicitly.
# ENABLE_OPENCLAW_PROXY=true
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token
# OPENCLAW_PROXY_HOST=127.0.0.1
# OPENCLAW_PROXY_PORT=18789
